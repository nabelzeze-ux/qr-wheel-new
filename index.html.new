<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>X-Team Pro Wheel</title>
    <style>
        :root {
            --gold: #ffcc00;
            --dark-bg: #121212;
            --red: #e63946;
            --black: #1a1a1a;
        }

        body {
            background-color: var(--dark-bg);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .header-title {
            font-size: 2.5rem;
            font-weight: bold;
            color: var(--gold);
            text-shadow: 0 0 10px rgba(255, 204, 0, 0.5);
            margin-bottom: 20px;
        }

        .wheel-container {
            position: relative;
            width: 350px;
            height: 350px;
            border: 10px solid var(--gold);
            border-radius: 50%;
            box-shadow: 0 0 20px rgba(255, 204, 0, 0.3);
        }

        #canvas {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            transition: transform 5s cubic-bezier(0.15, 0, 0.15, 1);
        }

        .pointer {
            position: absolute;
            top: -20px;
            left: 50%;
            transform: translateX(-50%);
            width: 40px;
            z-index: 10;
        }

        .spin-btn {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70px;
            height: 70px;
            background: radial-gradient(circle, #fff, var(--gold));
            border-radius: 50%;
            border: none;
            cursor: pointer;
            font-weight: bold;
            font-size: 14px;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
            z-index: 11;
        }

        /* تأثير الاحتفال */
        #result-popup {
            display: none;
            position: fixed;
   <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const spinSound = document.getElementById('spinSound');
    const winSound = document.getElementById('winSound');

    const prizes = [
        { label: "150,000 ل.س", weight: 0.5, color: "#e63946" },
        { label: "100,000 ل.س", weight: 1, color: "#1a1a1a" },
        { label: "50,000 ل.س", weight: 1.5, color: "#e63946" },
        { label: "25,000 ل.س", weight: 3, color: "#1a1a1a" },
        { label: "10,000 ل.س", weight: 14, color: "#e63946" },
        { label: "5,000 ل.س", weight: 20, color: "#1a1a1a" },
        { label: "1,000 ل.س", weight: 25, color: "#e63946" },
        { label: "%10 شحن", weight: 20, color: "#1a1a1a" },
        { label: "%20 شحن", weight: 15, color: "#e63946" }
    ];

    const numPrizes = prizes.length;
    const arc = Math.PI * 2 / numPrizes;
    let startAngle = 0;

    function drawWheel() {
        prizes.forEach((prize, i) => {
            const angle = startAngle + i * arc;
            ctx.fillStyle = prize.color;
            ctx.beginPath();
            ctx.moveTo(250, 250);
            ctx.arc(250, 250, 250, angle, angle + arc, false);
            ctx.lineTo(250, 250);
            ctx.fill();
            ctx.strokeStyle = "#ffcc00";
            ctx.lineWidth = 2;
            ctx.stroke();

            // إضافة النص
            ctx.save();
            ctx.translate(250, 250);
            ctx.rotate(angle + arc / 2);
            ctx.textAlign = "right";
            ctx.fillStyle = "white";
            ctx.font = "bold 18px Arial";
            ctx.fillText(prize.label, 230, 10);
            ctx.restore();
        });
    }

    function getWeightedPrize() {
        const totalWeight = prizes.reduce((sum, p) => sum + p.weight, 0);
        let random = Math.random() * totalWeight;
        for (let i = 0; i < prizes.length; i++) {
            if (random < prizes[i].weight) return i;
            random -= prizes[i].weight;
        }
    }

    let isSpinning = false;
    function spinWheel() {
        if (isSpinning) return;
        isSpinning = true;

        const prizeIndex = getWeightedPrize();
        const extraDegrees = (360 * 5); // 5 دورات كاملة
        const prizeDegree = (360 / numPrizes);
        
        // حساب الزاوية بدقة ليتوقف السهم عند الجائزة المختارة
        // ملاحظة: الحساب يعكس ترتيب المصفوفة ليتناسب مع اتجاه دوران العجلة
        const totalRotation = extraDegrees + (360 - (prizeIndex * prizeDegree)) - (prizeDegree / 2);

        spinSound.play();
        canvas.style.transform = `rotate(${totalRotation}deg)`;

        setTimeout(() => {
            isSpinning = false;
            winSound.play();
            showResult(prizes[prizeIndex].label);
        }, 5000);
    }

    function showResult(label) {
        document.getElementById('winner-text').innerText = label;
        document.getElementById('result-popup').style.display = 'block';
    }

    drawWheel();
</script>
</body>
</html>
         top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.9);
            padding: 30px;
            border: 2px solid var(--gold);
            border-radius: 15px;
            text-align: center;
            z-index: 100;
            animation: fadeIn 0.5s;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

    <div class="header-title">X-Team Pro</div>

    <div class="wheel-container">
        <img src="https://cdn-icons-png.flaticon.com/512/3585/3585145.png" class="pointer" alt="pointer">
        <canvas id="canvas" width="500" height="500"></canvas>
        <button class="spin-btn" onclick="spinWheel()">ابدأ</button>
    </div>

    <div id="result-popup">
        <h2 style="color: var(--gold);">مبروك! 🎉</h2>
        <p id="winner-text" style="font-size: 24px;"></p>
        <button onclick="document.getElementById('result-popup').style.display='none'" style="padding: 10px 20px;">إغلاق</button>
    </div>

    <audio id="spinSound" src="https://www.soundjay.com/misc/sounds/spinning-wheel-1.mp3"></audio>
    <audio id="winSound" src="https://www.soundjay.com/misc/sounds/bell-ringing-05.mp3"></audio>
